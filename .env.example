APP_ENV=development
APP_VERSION=0.1.0
LOG_LEVEL=INFO
DATABASE_URL=postgresql+asyncpg://broker:broker@postgres:5432/broker
CORS_ORIGINS=["http://localhost:3000"]
EXPOSE_DOCS=true
AUTH_PROVIDER=mock
SESSION_SECRET=dev-secret-change-me
# 세션 쿠키 정책 (T04a)
SESSION_COOKIE_NAME=broker_session
SESSION_TTL_SECONDS=28800
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
# COOKIE_DOMAIN= (운영 시 .example.cnu.ac.kr 등)
AUTH_LOGIN_PATH=/api/v1/auth/mock/login
ENABLE_METRICS=true
# 예약 도메인 정책 (T05)
RESERVATION_SLOT_MINUTES=30
MAX_CONCURRENT_RESERVATIONS=5
MAX_RESERVATION_HOURS_PER_DAY=8
MAX_RESERVATION_DURATION_MINUTES=240
RESERVATION_LOOKAHEAD_DAYS=14
# 동적 접속 토큰 정책 (T07) — 예약 시작 N초 전부터 토큰 발급 가능
CONNECT_TOKEN_GRACE_SECONDS=60
