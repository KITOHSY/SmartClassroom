From fa743449fc1123d553fd6a7e7cc3f3b0ad251fe6 Mon Sep 17 00:00:00 2001
From: KITOHSY <hongsun900912@gmail.com>
Date: Sun, 24 May 2026 01:18:34 +0900
Subject: [PATCH 11/11] T14: decode percent-encoded broker URL param
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

e2e(2026-05-24)에서 발견 — 스크림 핸들러로 들어온 moonlight:// URL의 broker
쿼리 값(예: `http%3A%2F%2Flocalhost%3A5173`)이 percent-encoded 상태로
ScBrokerClient까지 도달해 QUrl 파싱 실패 → "bad_broker_url" 폴백.

원인: scT13ExpandMoonlightConnectUrl / scT13DispatchMoonlightUrl 두 곳에서
queryItemValue("broker")를 기본 QUrl::PrettyDecoded 모드로 읽었는데, 그 모드는
`:` / `/` (`%3A`/`%2F`) 같은 reserved 문자를 *디코딩하지 않고 그대로 둠*.
token/IP/port는 영숫자라 PrettyDecoded로도 문제 없는데 broker는 URL이라 영향.

두 곳 모두 queryItemValue("broker", QUrl::FullyDecoded)로 변경. e2e 시나리오
①~④ 전부 통과 확인.
---
 app/main.cpp | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/app/main.cpp b/app/main.cpp
index 55374a99..3482ac2b 100644
--- a/app/main.cpp
+++ b/app/main.cpp
@@ -331,7 +331,7 @@ static QStringList scT13ExpandMoonlightConnectUrl(const QStringList& args)
         const QString hostId = q.queryItemValue("host-id");
         const QString host   = q.queryItemValue("host");
         const QString port   = q.queryItemValue("port");
-        const QString broker = q.queryItemValue("broker");
+        const QString broker = q.queryItemValue("broker", QUrl::FullyDecoded);
         if (host.isEmpty()) {
             qWarning() << "moonlight:// URL missing host parameter:" << arg;
             continue;
@@ -446,7 +446,7 @@ static void scT13DispatchMoonlightUrl(const QUrl& url)
     const QString host   = q.queryItemValue("host");
     const QString hostId = q.queryItemValue("host-id");
     const QString port   = q.queryItemValue("port");
-    const QString broker = q.queryItemValue("broker");
+    const QString broker = q.queryItemValue("broker", QUrl::FullyDecoded);
     if (host.isEmpty()) {
         qWarning() << "T13: moonlight:// URL missing host parameter:" << url.toString();
         return;
-- 
