diff --git a/app/backend/scnotificationclient.cpp b/app/backend/scnotificationclient.cpp
new file mode 100644
index 00000000..a2ac9fa4
--- /dev/null
+++ b/app/backend/scnotificationclient.cpp
@@ -0,0 +1,172 @@
+#include "scnotificationclient.h"
+
+#include <QDebug>
+#include <QJsonArray>
+#include <QJsonDocument>
+#include <QJsonObject>
+#include <QLatin1String>
+#include <QNetworkReply>
+#include <QNetworkRequest>
+#include <QUrl>
+
+// 10 s polling interval — ±10 s display accuracy KPI is met (worst case ~10 s
+// lag from scheduled_at to user-visible notification).
+#define SC_NOTIFICATION_POLL_INTERVAL_MS 10000
+#define SC_NOTIFICATION_TIMEOUT_MS 8000
+#define SC_NOTIFICATION_MAX_FAILURES 3
+
+ScNotificationClient::ScNotificationClient(QObject* parent)
+    : QObject(parent)
+{
+    m_PollTimer.setInterval(SC_NOTIFICATION_POLL_INTERVAL_MS);
+    m_PollTimer.setSingleShot(false);
+    connect(&m_PollTimer, &QTimer::timeout, this, &ScNotificationClient::pollOnce);
+}
+
+void ScNotificationClient::start(const QString& brokerUrl,
+                                  const QString& connectToken,
+                                  int reservationId)
+{
+    QUrl url(brokerUrl);
+    if (!url.isValid() || url.host().isEmpty()) {
+        qWarning() << "T15: invalid broker URL for notifications:" << brokerUrl;
+        emit pollingFailed(QLatin1String("bad_broker_url"));
+        return;
+    }
+    m_BrokerUrl = brokerUrl;
+    m_ConnectToken = connectToken;
+    m_ReservationId = reservationId;
+    m_ConsecutiveFailures = 0;
+
+    qInfo() << "T15: notification polling started for reservation"
+            << reservationId;
+    // Fire once immediately so the user sees pending modals without waiting up
+    // to 10 s — handles the case where the broker already enqueued before we
+    // joined the session.
+    pollOnce();
+    m_PollTimer.start();
+}
+
+void ScNotificationClient::stop()
+{
+    m_PollTimer.stop();
+    qInfo() << "T15: notification polling stopped";
+}
+
+void ScNotificationClient::pollOnce()
+{
+    QUrl url(m_BrokerUrl);
+    url.setPath(QLatin1String("/api/v1/notifications"));
+
+    QNetworkRequest request(url);
+    request.setRawHeader(
+        "Authorization",
+        QByteArray("Bearer ") + m_ConnectToken.toUtf8());
+    request.setTransferTimeout(SC_NOTIFICATION_TIMEOUT_MS);
+
+    QNetworkReply* reply = m_Nam.get(request);
+    connect(reply, &QNetworkReply::finished, this, [this, reply]() {
+        reply->deleteLater();
+
+        const int httpStatus =
+            reply->attribute(QNetworkRequest::HttpStatusCodeAttribute).toInt();
+
+        if (httpStatus == 0 || httpStatus >= 500) {
+            m_ConsecutiveFailures++;
+            qWarning() << "T15: notification polling failed — status"
+                       << httpStatus << "error" << reply->errorString();
+            if (m_ConsecutiveFailures >= SC_NOTIFICATION_MAX_FAILURES) {
+                emit pollingFailed(QStringLiteral("http_%1").arg(httpStatus));
+            }
+            return;
+        }
+        m_ConsecutiveFailures = 0;
+
+        if (httpStatus != 200) {
+            qWarning() << "T15: notification polling rejected — status" << httpStatus;
+            return;
+        }
+
+        const QJsonDocument doc = QJsonDocument::fromJson(reply->readAll());
+        if (!doc.isObject()) {
+            return;
+        }
+        const QJsonArray items = doc.object()
+                                      .value(QLatin1String("items"))
+                                      .toArray();
+        for (const QJsonValue& v : items) {
+            if (!v.isObject()) continue;
+            const QJsonObject item = v.toObject();
+            const int id = item.value(QLatin1String("id")).toInt();
+            const QString kind = item.value(QLatin1String("kind")).toString();
+            const QJsonObject payload =
+                item.value(QLatin1String("payload")).toObject();
+            const QString message =
+                payload.value(QLatin1String("message")).toString();
+            const QDateTime endsAt = QDateTime::fromString(
+                payload.value(QLatin1String("ends_at")).toString(),
+                Qt::ISODateWithMs);
+            emit notificationReceived(id, kind, message, endsAt);
+        }
+    });
+}
+
+void ScNotificationClient::ackNotification(int notificationId)
+{
+    QUrl url(m_BrokerUrl);
+    url.setPath(QStringLiteral("/api/v1/notifications/%1/ack").arg(notificationId));
+
+    QNetworkRequest request(url);
+    request.setRawHeader(
+        "Authorization",
+        QByteArray("Bearer ") + m_ConnectToken.toUtf8());
+    request.setHeader(QNetworkRequest::ContentTypeHeader,
+                      QLatin1String("application/json"));
+    request.setTransferTimeout(SC_NOTIFICATION_TIMEOUT_MS);
+
+    QNetworkReply* reply = m_Nam.post(request, QByteArray());
+    connect(reply, &QNetworkReply::finished, this, [reply, notificationId]() {
+        reply->deleteLater();
+        const int httpStatus =
+            reply->attribute(QNetworkRequest::HttpStatusCodeAttribute).toInt();
+        if (httpStatus != 200) {
+            qWarning() << "T15: notification ACK failed for id"
+                       << notificationId << "status" << httpStatus;
+        }
+    });
+}
+
+void ScNotificationClient::postExplicitEnd(const QString& reason)
+{
+    if (m_ReservationId <= 0) {
+        qWarning() << "T15: postExplicitEnd called before start()";
+        return;
+    }
+    QUrl url(m_BrokerUrl);
+    url.setPath(QStringLiteral("/api/v1/reservations/%1/end").arg(m_ReservationId));
+
+    QJsonObject body;
+    body[QLatin1String("reason")] = reason;
+
+    QNetworkRequest request(url);
+    request.setRawHeader(
+        "Authorization",
+        QByteArray("Bearer ") + m_ConnectToken.toUtf8());
+    request.setHeader(QNetworkRequest::ContentTypeHeader,
+                      QLatin1String("application/json"));
+    request.setTransferTimeout(SC_NOTIFICATION_TIMEOUT_MS);
+
+    QNetworkReply* reply = m_Nam.post(
+        request, QJsonDocument(body).toJson(QJsonDocument::Compact));
+    connect(reply, &QNetworkReply::finished, this, [reply, reason]() {
+        reply->deleteLater();
+        const int httpStatus =
+            reply->attribute(QNetworkRequest::HttpStatusCodeAttribute).toInt();
+        if (httpStatus == 200) {
+            qInfo() << "T15: explicit end accepted (reason:" << reason << ")";
+        } else {
+            qWarning() << "T15: explicit end rejected — status"
+                       << httpStatus;
+        }
+    });
+}
diff --git a/app/backend/scnotificationclient.h b/app/backend/scnotificationclient.h
new file mode 100644
index 00000000..8712c63c
--- /dev/null
+++ b/app/backend/scnotificationclient.h
@@ -0,0 +1,66 @@
+#pragma once
+
+#include <QDateTime>
+#include <QNetworkAccessManager>
+#include <QObject>
+#include <QString>
+#include <QTimer>
+
+// SmartClassroom T15 — bi-directional modal channel client.
+//
+// Polls the Broker (GET <brokerUrl>/api/v1/notifications) every 10 seconds while
+// a session is active to retrieve queued modals (session_ending warning,
+// host_shutdown_request). Acks each notification once displayed.
+//
+// Auth: same Bearer connect token used elsewhere (Broker verifies it without
+// consuming — multi-use until reservation.ends_at).
+//
+// Asynchronous: start() begins polling; notificationReceived() fires per item
+// returned; ackNotification() POSTs the ACK.
+class ScNotificationClient : public QObject
+{
+    Q_OBJECT
+
+public:
+    explicit ScNotificationClient(QObject* parent = nullptr);
+
+    // brokerUrl: Broker base URL (e.g. "https://broker.example") — same as the
+    //            moonlight:// `broker` parameter.
+    // connectToken: raw connect token (Bearer authenticator).
+    // reservationId: for downstream session lifecycle calls (POST /reservations/{id}/end).
+    void start(const QString& brokerUrl,
+               const QString& connectToken,
+               int reservationId);
+    void stop();
+
+    // Fire-and-forget ACK after a notification was displayed to the user. Failure
+    // is logged only — broker keeps the row alive and polling re-receives it
+    // until ack is successful.
+    void ackNotification(int notificationId);
+
+    // POST <brokerUrl>/api/v1/reservations/{id}/end — Moonlight's confirm side of
+    // the modal channel (explicit end). reason: "auto_modal" / "shortcut" /
+    // "host_shutdown" / "manual".
+    void postExplicitEnd(const QString& reason);
+
+signals:
+    // One signal per pending notification returned by polling.
+    // payload is the raw JSON object from broker as a QString (Qt's QJsonObject
+    // would force QJSON include cascade in the slot; QString keeps it simple).
+    void notificationReceived(int id, const QString& kind, const QString& message,
+                              QDateTime endsAt);
+
+    // Emitted on 3 consecutive polling failures so caller can fall back gracefully.
+    void pollingFailed(QString reason);
+
+private slots:
+    void pollOnce();
+
+private:
+    QNetworkAccessManager m_Nam;
+    QTimer m_PollTimer;
+    QString m_BrokerUrl;
+    QString m_ConnectToken;
+    int m_ReservationId = 0;
+    int m_ConsecutiveFailures = 0;
+};
