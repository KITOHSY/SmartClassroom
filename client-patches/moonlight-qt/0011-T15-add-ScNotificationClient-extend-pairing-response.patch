-void ComputerManager::scHandleBrokerPairingRelayed(bool success, QString reason)
+void ComputerManager::scHandleBrokerPairingRelayed(bool success, QString reason,
+                                                    int reservationId,
+                                                    QDateTime endsAt)
 {
     if (m_AutoPairingComputer == nullptr) {
         return;
     }
 
     if (success) {
+        // T15 — stash the reservation context so Session can wire up
+        // ScNotificationClient (modal channel polling).
+        if (reservationId > 0) {
+            QWriteLocker cLock(&m_AutoPairingComputer->lock);
+            m_AutoPairingComputer->pendingReservationId = reservationId;
+            m_AutoPairingComputer->pendingEndsAt = endsAt;
+        }
         // The PIN reached the host. The local handshake is now authoritative —
         // wait for its completion via scHandleHeadlessPairingResult().
-        qInfo() << "T14: Broker relayed PIN for" << m_AutoPairingComputer->name;
+        qInfo() << "T14: Broker relayed PIN for" << m_AutoPairingComputer->name
+                << "reservation_id" << reservationId;
         return;
     }
 
@@ -936,6 +946,10 @@ void ComputerManager::scClearPendingConnect(NvComputer* computer)
     computer->pendingConnectToken.clear();
     computer->pendingHostId = 0;
     computer->pendingBrokerUrl.clear();
+    // T15 — also clear reservation context. Session reads these before clear
+    // happens (auto-stream entry copies them out under the lock).
+    computer->pendingReservationId = 0;
+    computer->pendingEndsAt = QDateTime();
 }
 
